#!name=Ctrip Daily Bonus
#!desc=Ctrip auth capture + daily sign-in
#!author=NobyDa

[Script]
http-response ^https:\/\/m\.ctrip\.com\/restapi\/soa2\/\d+\/[a-zA-Z]+Login(?:$|\?) script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Ctrip-DailyBonus/Ctrip.js, requires-body=true, tag=携程旅行Cookie
cron "30 8 * * *" script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Ctrip-DailyBonus/Ctrip.js, timeout=300, tag=携程旅行签到

[MITM]
hostname = m.ctrip.com
